{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a5345534/goal-dag/schemas/model-catalog.schema.json",
  "title": "Goal DAG Model Routing Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["modelRouting"],
  "properties": {
    "modelRouting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rules"],
      "properties": {
        "controllerScenario": { "type": "string", "minLength": 1 },
        "defaultSubagentScenario": { "type": "string", "minLength": 1 },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/rule" }
        }
      }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["when", "modelScenario", "model"],
      "properties": {
        "when": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/conditionValue" }
        },
        "modelScenario": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 }
      }
    },
    "conditionValue": {
      "oneOf": [
        { "$ref": "#/$defs/conditionScalar" },
        {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/conditionScalar" }
        }
      ]
    },
    "conditionScalar": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "number" },
        { "type": "boolean" }
      ]
    }
  }
}
