{
  "modelRouting": {
    "defaultSubagentScenario": "spark-implementation",
    "rules": [
      {
        "when": {
          "taskType": ["isolated-patch", "small-bugfix", "lint-fix", "type-fix", "unit-test-fix"],
          "risk": ["low", "medium"],
          "contextTokensEstimated": "<=128000"
        },
        "modelScenario": "spark-implementation",
        "model": "openai-codex/gpt-5.3-codex-spark"
      },
      {
        "when": {
          "taskType": ["repo-scan", "triage", "module-map", "dependency-discovery", "context-collection"]
        },
        "modelScenario": "long-context-scan",
        "model": "deepseek/deepseek-v4-flash"
      },
      {
        "when": {
          "contextTokensEstimated": ">128000",
          "taskType": ["coding", "debugging", "analysis", "review"]
        },
        "modelScenario": "long-context-reasoning",
        "model": "deepseek/deepseek-v4-pro"
      },
      {
        "when": {
          "taskType": ["cross-module-debugging", "medium-risk-refactor", "integration-fix", "test-suite-fix"],
          "risk": "medium"
        },
        "modelScenario": "implementation",
        "model": "deepseek/deepseek-v4-pro"
      },
      {
        "when": {
          "taskType": ["review", "audit", "spec-validation", "regression-risk-check"],
          "risk": ["medium", "high"]
        },
        "modelScenario": "review",
        "model": "deepseek/deepseek-v4-pro"
      },
      {
        "when": {
          "risk": "critical"
        },
        "modelScenario": "critical-decision",
        "model": "openai-codex/gpt-5.5"
      },
      {
        "when": {
          "taskType": ["architecture-decision", "final-merge-review", "production-migration-plan", "security-sensitive-change"]
        },
        "modelScenario": "final-authority",
        "model": "openai-codex/gpt-5.5"
      },
      {
        "when": {
          "privacy": "local-only",
          "risk": "low"
        },
        "modelScenario": "local-private",
        "model": "local-aeon/aeon"
      },
      {
        "when": {
          "taskType": ["docs", "spec", "markdown"],
          "risk": "low",
          "contextTokensEstimated": "<=128000"
        },
        "modelScenario": "spark-docs",
        "model": "openai-codex/gpt-5.3-codex-spark"
      },
      {
        "when": {
          "taskType": ["docs", "spec", "markdown"],
          "contextTokensEstimated": ">128000"
        },
        "modelScenario": "long-context-docs",
        "model": "deepseek/deepseek-v4-flash"
      }
    ]
  }
}
